# По умолчанию нормализуем переносы строк к LF в репозитории.
* text=auto eol=lf

# Бинарные файлы — без обработки.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary

# Lock-файлы оставляем как есть, generated помечаем для GitHub diff.
pnpm-lock.yaml linguist-generated=true
src-tauri/Cargo.lock linguist-generated=true
auto-imports.d.ts linguist-generated=true
components.d.ts linguist-generated=true
.eslintrc-auto-import.json linguist-generated=true

# На Windows .cmd и .bat должны иметь CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
